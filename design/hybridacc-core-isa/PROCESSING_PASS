
let WEIGHT_BASE_ADDR 0x00000000
let INPUT_BASE_ADDR 0x00010000
let OUTPUT_BASE_ADDR 0x00020000
let TEMP_BUFFER_ADDR 0x00030000

let NOC_PS_OFFSET 0x00
let NOC_PD_OFFSET 0x40
let NOC_PI_OFFSET 0x80
let NOC_PO_OFFSET 0xc0

let CORE_ROWS 4
let CORE_COLS 16

let KERNEL_SIZE 3
let STRIDE 1
let PADDING 1
let CONV2D_PASS_CO 64  // Output channels per pass
let CONV2D_PASS_CI_K3 4  // Input channels per pass for 3x3 kernel
let CONV2D_PASS_HO CORE_COLS
let CONV2D_PASS_HI (CONV2D_PASS_HO - 1) * STRIDE + KERNEL_SIZE  // Input height per pass
let CONV2D_PASS_WO 200
let CONV2D_PASS_WI (CONV2D_PASS_WO - 1) * STRIDE + KERNEL_SIZE  // Input width per pass

// load PE instructions
// TBD

// load weights into PEs
for co from 0 to CONV2D_PASS_CO step 1 do // 64
    for kh from 0 to KERNEL_SIZE step 1 do // 3
        for kw from 0 to KERNEL_SIZE step 1 do // 3
            for ci from 0 to CONV2D_PASS_CI_K3 step 4 do // 4
                let dm_addr = WEIGHT_BASE_ADDR + (((co * CONV2D_PASS_CI_K3 + ci) * KERNEL_SIZE + kh) * KERNEL_SIZE + kw) // order=CO_CI_KH_KW
                vector weight_data = VLOAD(dm_addr)
                let noc_addr = NOC_PS_OFFSET + (kh * KERNEL_SIZE + kw) * CONV2D_PASS_CI_K3 + ci // send along kernel and input channel dimensions
                VSTORE(noc_addr, weight_data)
            endfor
        endfor
    endfor
endfor

// main processing loop
for wi from 0 to CONV2D_PASS_WI step 1 do // 200
    // send input activations
    for hi from 0 to CONV2D_PASS_HI step 1 do // 16
        for ci from 0 to CONV2D_PASS_CI_K3 step 1 do // 4
            if wi < PADDING or wi >= CONV2D_PASS_WI - PADDING then
                let noc_addr = NOC_PD_OFFSET + hi // send along height dimension
                VSTORE(noc_addr, 0) // send zero for padding
                continue
            end
            let dm_addr = INPUT_BASE_ADDR + (ci * CONV2D_PASS_HI + hi) * CONV2D_PASS_WI + wi // order=CHW
            let noc_addr = NOC_PD_OFFSET + hi // send along height dimension
            vector data = VLOAD(dm_addr)
            VSTORE(noc_addr, data)
        endfor
    endfor

    // send input partial sums
    for ho from 0 to CONV2D_PASS_HO step 1 do // 16
        for co from 0 to CONV2D_PASS_CO step 4 do // 64
            let dm_addr = OUTPUT_BASE_ADDR + (co * CONV2D_PASS_HO + ho) * CONV2D_PASS_WO + wi // order=CHW
            let noc_addr = NOC_PI_OFFSET + ho // send along height dimension for partial sums
            vector partial_sum = VLOAD(dm_addr) // corrected to load from dm_addr
            VSTORE(noc_addr, partial_sum) // store the partial sum
        endfor
    endfor

    // receive output partial sums
    for ho from 0 to CONV2D_PASS_HO step 1 do // 16
        for co from 0 to CONV2D_PASS_CO step 4 do // 64
            let noc_addr = NOC_PO_OFFSET + ho // receive along height dimension for output partial sums
            vector output_data = VLOAD(noc_addr)
            let dm_addr = OUTPUT_BASE_ADDR + (co * CONV2D_PASS_HO + ho) * CONV2D_PASS_WO + wi // order=CHW
            VSTORE(dm_addr, output_data)
        endfor
    endfor
endfor
