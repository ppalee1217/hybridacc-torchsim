#Set Design Environments

set company "CIC"
set designer "Student"

set CoreSearchPath /cad/process/ADFP/Executable_Package/Collaterals/IP/stdcell/N16ADFP_StdCell/NLDM/
# set CoreSearchPath /cad/process/ADFP/Executable_Package/Collaterals/IP/stdcell/N16ADFP_StdCell/CCS/
set IOSearchPath   /cad/process/ADFP/Executable_Package/Collaterals/IP/stdio/N16ADFP_StdIO/NLDM/
set SRAMSearchPath /cad/process/ADFP/Executable_Package/Collaterals/IP/sram/N16ADFP_SRAM/NLDM/
# set MemoryPath ../sim/SRAM
# set DefintionPath  ../include

set search_path    "$CoreSearchPath $IOSearchPath $SRAMSearchPath $search_path"

set target_library   "N16ADFP_StdCellss0p72vm40c.db    N16ADFP_StdCellff0p88v125c.db \
                      N16ADFP_StdIOss0p72v1p62v125c.db N16ADFP_StdIOff0p88v1p98vm40c.db \
                     "

set sram_library     "N16ADFP_SRAM_ss0p72v0p72vm40c_100a.db N16ADFP_SRAM_ff0p88v0p88v125c_100a.db"

set link_library      "* $target_library $sram_library dw_foundation.sldb"
set symbol_library    "generic_sdb"
set synthetic_library "dw_foundation.sldb"

set verilogout_no_tri true
set hdlin_enable_presto_for_vhdl "TRUE"
set sh_enable_line_editing true
history keep 100
alias h history