    mmio_write32(DMA_DST_KIND,       DMA_ENDPOINT_CLUSTER_SPM);
    mmio_write32(DMA_SRC_ADDR_LO,    dram_addr);
    mmio_write32(DMA_DST_ADDR_LO,    spm_offset);
    mmio_write32(DMA_SRC_CLUSTER_ID, 0);
    mmio_write32(DMA_DST_CLUSTER_ID, cluster_id);
    mmio_write32(DMA_COUNT_D0,       beat_count);
    mmio_write32(DMA_CTRL,           DMA_CTRL_SUBMIT);
}

