    (void)mmio_read32(cluster_base + HDDU_BASE + HDDU_ERR_INFO0);
    (void)mmio_read32(cluster_base + HDDU_BASE + HDDU_ERR_INFO1);
    (void)mmio_read32(cluster_base + HDDU_BASE + HDDU_COUNTER_STALL);
    (void)mmio_read32(cluster_base + agu_addr(AGU_PS,  AGU_REG_STATUS));
    (void)mmio_read32(cluster_base + agu_addr(AGU_PD,  AGU_REG_STATUS));
    (void)mmio_read32(cluster_base + agu_addr(AGU_PLI, AGU_REG_STATUS));
    (void)mmio_read32(cluster_base + agu_addr(AGU_PLO, AGU_REG_STATUS));
}

static inline void wait_all_clusters_hddu_done(uint32_t num_clusters) {
    for (uint32_t c = 0; c < num_clusters; c++) {
        uint32_t base = CLUSTER_UNICAST_BASE + c * CLUSTER_STRIDE;
        uint32_t spin_count = 0;
        while (1) {
            uint32_t st = mmio_read32(base + HDDU_BASE + HDDU_STATUS);
            if ((st & HDDU_STATUS_QUIESCED) && ((spin_count & 0xFFu) == 0u)) {
                hddu_wait_debug_probe(base);
            }
            if (st & HDDU_STATUS_ERROR) return;
            if (st & HDDU_STATUS_DONE) break;
            spin_count++;
            arm_wfi_timer_tick(32u);
            __asm__ volatile("wfi");
        }
    }
}

static inline void wait_all_clusters_done(uint32_t num_clusters) {
    /* Temporary compatibility wrapper until all call sites move to hddu_done. */
    wait_all_clusters_hddu_done(num_clusters);
}

static inline void wait_all_clusters_agu_idle(uint32_t num_clusters) {
    for (uint32_t c = 0; c < num_clusters; c++) {
        uint32_t base = CLUSTER_UNICAST_BASE + c * CLUSTER_STRIDE;
        while (1) {
            uint32_t ps  = mmio_read32(base + agu_addr(AGU_PS,  AGU_REG_STATUS));
            uint32_t pd  = mmio_read32(base + agu_addr(AGU_PD,  AGU_REG_STATUS));
            uint32_t pli = mmio_read32(base + agu_addr(AGU_PLI, AGU_REG_STATUS));
            uint32_t plo = mmio_read32(base + agu_addr(AGU_PLO, AGU_REG_STATUS));
            if (((ps | pd | pli | plo) & 0x2u) == 0u) {
                break;
            }
            arm_wfi_timer_tick(32u);
            __asm__ volatile("wfi");
        }
    }
}

static inline void wait_all_clusters_pe_halted(uint32_t num_clusters) {
    for (uint32_t c = 0; c < num_clusters; c++) {
        uint32_t base = CLUSTER_UNICAST_BASE + c * CLUSTER_STRIDE;
        while (1) {
            uint32_t st = mmio_read32(base + NOC_STATUS);
            if (st & NOC_STATUS_ALL_ACTIVE_PES_HALTED) {
                break;
            }
            arm_wfi_timer_tick(32u);
            __asm__ volatile("wfi");
        }
    }
}

static inline void wait_all_clusters_noc_quiesced(uint32_t num_clusters) {
    for (uint32_t c = 0; c < num_clusters; c++) {
        uint32_t base = CLUSTER_UNICAST_BASE + c * CLUSTER_STRIDE;
        while (1) {
            uint32_t st = mmio_read32(base + NOC_STATUS);
            uint32_t required = NOC_STATUS_ALL_ACTIVE_PES_HALTED;
            uint32_t blocked = NOC_STATUS_ANY_ROUTER_PENDING_RESP
                             | NOC_STATUS_ANY_ROUTER_FIFO_NONEMPTY;
            if ((st & required) == required && (st & blocked) == 0u) {
                break;
            }
            arm_wfi_timer_tick(32u);
            __asm__ volatile("wfi");
        }
    }
}

static inline void wait_all_clusters_cluster_idle(uint32_t num_clusters) {
    for (uint32_t c = 0; c < num_clusters; c++) {
        while (1) {
            uint32_t st = cluster_unicast_read32(c, CLUSTER_STATUS);
            if (st & CLUSTER_STATUS_ERROR) return;
            if (st & CLUSTER_STATUS_IDLE) {
                break;
            }
            arm_wfi_timer_tick(32u);
            __asm__ volatile("wfi");
        }
    }
}

static inline void wait_all_clusters_cluster_quiesced(uint32_t num_clusters) {
    for (uint32_t c = 0; c < num_clusters; c++) {
        while (1) {
            uint32_t st = cluster_unicast_read32(c, CLUSTER_STATUS);
