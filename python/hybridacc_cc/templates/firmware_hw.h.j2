static inline void enable_wfi_timer_interrupts(void) {
    mmio_write32(TIMER_CTRL, 1u);
    mmio_write32(TIMER_MTIMECMP_LO, 0xFFFFFFFFu);
    mmio_write32(TIMER_MTIMECMP_HI, 0xFFFFFFFFu);
    csr_set_bits(CSR_MIE, MIE_MTIE);
    csr_set_bits(CSR_MSTATUS, MSTATUS_MIE);
}

static inline void arm_wfi_timer_tick(uint32_t delta_cycles) {
    uint32_t now_lo = mmio_read32(TIMER_MTIME_LO);
    mmio_write32(TIMER_MTIMECMP_HI, 0xFFFFFFFFu);
    mmio_write32(TIMER_MTIMECMP_LO, now_lo + delta_cycles);
    mmio_write32(TIMER_MTIMECMP_HI, 0u);
}

static inline void hddu_wait_debug_probe(uint32_t cluster_base) {
