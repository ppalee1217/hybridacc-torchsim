    mmio_write32(DMA_SRC_CLUSTER_ID, cluster_id);
    mmio_write32(DMA_DST_CLUSTER_ID, 0);
    mmio_write32(DMA_COUNT_D0,       beat_count);
    mmio_write32(DMA_COUNT_D1,       1);
    mmio_write32(DMA_COUNT_D2,       1);
    mmio_write32(DMA_COUNT_D3,       1);
    mmio_write32(DMA_SRC_STRIDE_D0,  BEAT_BYTES);
    mmio_write32(DMA_SRC_STRIDE_D1,  0);
    mmio_write32(DMA_SRC_STRIDE_D2,  0);
    mmio_write32(DMA_SRC_STRIDE_D3,  0);
