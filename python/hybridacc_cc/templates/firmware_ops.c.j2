/* ═══════════════════════════════════════════════════════
 * Software multiply for RV32I (no M/Zmmul extension)
 * GCC emits __mulsi3 calls when -march lacks multiply.
 * ═══════════════════════════════════════════════════════ */
unsigned int __mulsi3(unsigned int a, unsigned int b) {
    unsigned int r = 0;
    while (a) {
        if (a & 1) r += b;
        a >>= 1;
        b <<= 1;
    }
    return r;
}
{% endif %}

unsigned int __udivsi3(unsigned int num, unsigned int den) {
    unsigned int quotient = 0;
    unsigned int shift = 0;

    if (den == 0) {
        return 0;
    }

    while (((den << 1) > den) && ((den << 1) <= num)) {
        den <<= 1;
        shift++;
    }

    while (1) {
        quotient <<= 1;
        if (num >= den) {
            num -= den;
            quotient |= 1u;
        }
        if (shift == 0) {
            break;
        }
        den >>= 1;
        shift--;
    }

    return quotient;
}

