static inline WaveCoord make_first_wave_coord(const TilingParams* t) {
    WaveCoord coord;

    coord.oc = 0;
    coord.h = 0;
    coord.w = 0;
    coord.ic = 0;
    coord.valid = (t->num_oc_tiles > 0)
               && (t->num_h_tiles > 0)
               && (t->num_w_tiles > 0)
               && (t->num_ic_tiles > 0);
    return coord;
}

static inline uint8_t advance_wave_coord(const TilingParams* t, WaveCoord* coord) {
    if (!coord->valid) {
        return 0;
    }

    coord->ic++;
    if (coord->ic < t->num_ic_tiles) {
        return 1;
    }

    coord->ic = 0;
    coord->w++;
    if (coord->w < t->num_w_tiles) {
        return 1;
    }

    coord->w = 0;
    coord->h++;
    if (coord->h < t->num_h_tiles) {
        return 1;
    }

    coord->h = 0;
    coord->oc++;
    if (coord->oc < t->num_oc_tiles) {
        return 1;
    }

    coord->valid = 0;
    return 0;
}

static inline uint8_t advance_wave_coord_gemm(const TilingParams* t, WaveCoord* coord) {
    if (!coord->valid) {
        return 0;
    }

    coord->ic++;
    if (coord->ic < t->num_ic_tiles) {
        return 1;
    }

    coord->ic = 0;
    coord->w++;
    if (coord->w < t->num_w_tiles) {
        return 1;
    }

    coord->w = 0;
    coord->oc++;
    if (coord->oc < t->num_oc_tiles) {
        return 1;
    }

    coord->oc = 0;
    coord->h++;
    if (coord->h < t->num_h_tiles) {
        return 1;
    }

    coord->valid = 0;
    return 0;
}

static inline void copy_wave_coord(WaveCoord* dst, const WaveCoord* src) {
    dst->oc = src->oc;
    dst->h = src->h;
    dst->w = src->w;
    dst->ic = src->ic;
    dst->valid = src->valid;
}

static inline void build_wave_runtime(const TilingParams* t,
                                      const SpatialDmaRuntime* spatial,
                                      const WaveCoord* coord,
                                      uint32_t wave_count,
                                      WaveRuntime* wave) {
    wave->valid = coord->valid;
    if (!coord->valid) {
        return;
    }

    uint32_t buf = wave_count & 1u;

    wave->ps_buf = (uint8_t)buf;

    wave->agu_base_ps  = buf ? t->agu_pong[0] : t->agu_ping[0];
    wave->agu_base_pd  = (buf ? t->agu_pong[1] : t->agu_ping[1])
                       + coord->ic * t->pd_ic_agu_offset;
    wave->agu_base_pli = buf ? t->agu_pong[2] : t->agu_ping[2];
    wave->agu_base_plo = t->agu_ping[3];

    wave->spm_map = (coord->ic & 1u) ? t->spm_map_odd : t->spm_map_even;

    wave->dram_ps = t->dram_weight_base
                  + coord->oc * t->dram_ps_oc_stride
                  + coord->h  * t->dram_ps_h_stride
                  + coord->ic * t->dram_ps_ic_stride;
    wave->dram_pd = t->dram_input_base
                  + coord->oc * t->dram_pd_oc_stride
                  + coord->ic * t->dram_pd_ic_stride;
    if (t->input_pad_enable) {
        wave->pd_pad_window_h0 = (int32_t)(coord->h * t->tile_h_out * t->input_stride)
                               - (int32_t)t->input_padding;
        wave->pd_pad_window_w0 = (int32_t)(coord->w * t->tile_w_out * t->input_stride)
                               - (int32_t)t->input_padding;
    } else {
        wave->dram_pd += coord->h * t->dram_pd_h_stride
                       + coord->w * t->dram_pd_w_stride;
        wave->pd_pad_window_h0 = 0;
        wave->pd_pad_window_w0 = 0;
    }
    wave->dram_out = t->dram_output_base
                   + coord->oc * t->dram_out_oc_stride
                   + coord->h  * t->dram_out_h_stride
                   + coord->w  * t->dram_out_w_stride;
    wave->dram_bias = t->dram_bias_base
                    + coord->oc * t->dram_bias_oc_stride
                    + coord->h  * t->dram_bias_h_stride;

    wave->spm_ps  = buf ? t->spm_pong[0] : t->spm_ping[0];
    wave->spm_pd  = buf ? t->spm_pong[1] : t->spm_ping[1];
    wave->spm_pli = buf ? t->spm_pong[2] : t->spm_ping[2];
    wave->spm_plo = (coord->ic & 1u) ? t->spm_pong[3] : t->spm_ping[3];

    wave->pd_row_beats = t->dma_pd_words;
    wave->pd_row_count = 1;
    wave->pli_row_beats = t->dma_pli_words;
    wave->pli_row_count = 1;
    wave->plo_row_beats = t->dma_plo_words;
    wave->plo_row_count = 1;
    wave->valid_h_out = tile_extent(coord->h, t->num_h_tiles,
                                    t->tile_h_out, t->last_h_out);
    wave->valid_w_out = tile_extent(coord->w, t->num_w_tiles,
                                    t->tile_w_out, t->last_w_out);
    wave->valid_h_in = wave->valid_h_out + spatial->pd_input_halo;
    wave->valid_w_in = wave->valid_w_out + spatial->pd_input_w_halo;

    if (t->spatial_2d_dma) {
        wave->pd_row_beats = wave->valid_w_in * spatial->pd_words_per_spatial;
        wave->pd_row_count = wave->valid_h_in;
        wave->pli_row_beats = wave->valid_w_out * spatial->pli_words_per_spatial;
        wave->pli_row_count = wave->valid_h_out;
        wave->plo_row_beats = wave->valid_w_out * spatial->plo_words_per_spatial;
        wave->plo_row_count = wave->valid_h_out;
    }

    wave->is_last_ic = (coord->ic + 1u == t->num_ic_tiles);
    wave->need_ps_dma = !t->ps_reuse_across_spatial
                     || ((coord->h == 0u) && (coord->w == 0u));
    wave->need_bias_dma = (coord->ic == 0u)
                       && (t->dma_pli_words > 0u);
}

static inline uint8_t gemm_ps_cache_lookup(const GemmPsCache* cache,
                                           uint32_t dram_ps) {
    if ((cache->valid_mask & 0x1u) && (cache->dram_ps[0] == dram_ps)) {
        return 0u;
    }
    if ((cache->valid_mask & 0x2u) && (cache->dram_ps[1] == dram_ps)) {
        return 1u;
    }
    return 0xFFu;
}

static inline void build_wave_runtime_gemm(const TilingParams* t,
                                           const SpatialDmaRuntime* spatial,
                                           const WaveCoord* coord,
                                           uint32_t wave_count,
                                           uint8_t active_ps_buf,
                                           GemmPsCache* ps_cache,
                                           WaveRuntime* wave) {
    uint8_t ps_buf;

    build_wave_runtime(t, spatial, coord, wave_count, wave);
    if (!wave->valid) {
        return;
    }

    ps_buf = gemm_ps_cache_lookup(ps_cache, wave->dram_ps);
    if (ps_buf == 0xFFu) {
        ps_buf = active_ps_buf ^ 1u;
        ps_cache->dram_ps[ps_buf] = wave->dram_ps;
        ps_cache->valid_mask |= (uint8_t)(1u << ps_buf);
        wave->need_ps_dma = 1u;
    } else {
        wave->need_ps_dma = 0u;
    }

    wave->ps_buf = ps_buf;
    wave->agu_base_ps = ps_buf ? t->agu_pong[0] : t->agu_ping[0];
    wave->spm_ps = ps_buf ? t->spm_pong[0] : t->spm_ping[0];
}

/* ── Prefetch State Machine ── */
#define MAX_PREFETCH_OPS 8
typedef struct {
    uint32_t dram_addr;
    uint32_t spm_addr;
    uint32_t beat_count;
    uint32_t row_count;
    uint32_t src_row_stride;
    uint32_t dst_row_stride;
    uint8_t  is_2d;
} PrefetchOp;

static PrefetchOp prefetch_queue[MAX_PREFETCH_OPS];
static uint32_t   prefetch_count;
static uint32_t   prefetch_last_tag;

static void prefetch_enqueue_linear(uint32_t dram, uint32_t spm,
                                    uint32_t beats) {
    if (prefetch_count < MAX_PREFETCH_OPS) {
        prefetch_queue[prefetch_count].dram_addr  = dram;
        prefetch_queue[prefetch_count].spm_addr   = spm;
        prefetch_queue[prefetch_count].beat_count = beats;
        prefetch_queue[prefetch_count].row_count = 1;
        prefetch_queue[prefetch_count].src_row_stride = 0;
        prefetch_queue[prefetch_count].dst_row_stride = 0;
        prefetch_queue[prefetch_count].is_2d = 0;
        prefetch_count++;
    }
}

static void prefetch_enqueue_2d(uint32_t dram, uint32_t spm,
                                uint32_t row_beats,
                                uint32_t row_count,
                                uint32_t src_row_stride,
                                uint32_t dst_row_stride) {
    if (prefetch_count < MAX_PREFETCH_OPS) {
        prefetch_queue[prefetch_count].dram_addr = dram;
        prefetch_queue[prefetch_count].spm_addr = spm;
        prefetch_queue[prefetch_count].beat_count = row_beats;
        prefetch_queue[prefetch_count].row_count = row_count;
        prefetch_queue[prefetch_count].src_row_stride = src_row_stride;
        prefetch_queue[prefetch_count].dst_row_stride = dst_row_stride;
        prefetch_queue[prefetch_count].is_2d = 1;
        prefetch_count++;
    }
}

static void prefetch_enqueue_parallel_rows(uint32_t dram,
                                          uint32_t spm,
                                          uint32_t row_beats,
                                          uint32_t total_rows,
                                          uint32_t rows_per_bank,
                                          uint32_t bank_depth_bytes) {
    uint32_t row_start = 0u;
    uint32_t banks = active_parallel_banks(total_rows, rows_per_bank);
    for (uint32_t b = 0; (b < banks) && (prefetch_count < MAX_PREFETCH_OPS); b++) {
        uint32_t bank_rows = bank_rows_for(total_rows, rows_per_bank, b);
        uint32_t bank_words = row_beats * bank_rows;
        if (bank_words == 0u) {
            break;
        }
        prefetch_enqueue_linear(dram + row_start * row_beats * BEAT_BYTES,
                                spm + b * bank_depth_bytes,
                                bank_words);
        row_start += bank_rows;
    }
}

static void prefetch_enqueue_parallel_words(uint32_t dram,
                                            uint32_t spm,
                                            uint32_t total_words,
                                            uint32_t words_per_bank,
                                            uint32_t bank_depth_bytes) {
    uint32_t word_start = 0u;
    uint32_t banks = active_parallel_words(total_words, words_per_bank);
    for (uint32_t b = 0; (b < banks) && (prefetch_count < MAX_PREFETCH_OPS); b++) {
        uint32_t bank_words = bank_words_for(total_words, words_per_bank, b);
        if (bank_words == 0u) {
            break;
        }
        prefetch_enqueue_linear(dram + word_start * BEAT_BYTES,
                                spm + b * bank_depth_bytes,
                                bank_words);
        word_start += bank_words;
    }
}

static void prefetch_enqueue_parallel_rows_2d(uint32_t dram,
                                              uint32_t spm,
                                              uint32_t row_beats,
                                              uint32_t total_rows,
                                              uint32_t rows_per_bank,
                                              uint32_t bank_depth_bytes,
                                              uint32_t src_row_stride,
                                              uint32_t dst_row_stride) {
    uint32_t row_start = 0u;
    uint32_t banks = active_parallel_banks(total_rows, rows_per_bank);
    for (uint32_t b = 0; (b < banks) && (prefetch_count < MAX_PREFETCH_OPS); b++) {
        uint32_t bank_rows = bank_rows_for(total_rows, rows_per_bank, b);
        if (bank_rows == 0u) {
            break;
        }
        prefetch_enqueue_2d(dram + row_start * src_row_stride,
                            spm + b * bank_depth_bytes,
                            row_beats,
                            bank_rows,
                            src_row_stride,
                            dst_row_stride);
        row_start += bank_rows;
    }
}

static void prefetch_start(void) {
    if (prefetch_count > 0) {
        for (uint32_t i = 0; i < prefetch_count; i++) {
            PrefetchOp* op = &prefetch_queue[i];
            dma_tag++;
            if (op->is_2d) {
                dma_load_2d(op->dram_addr, op->spm_addr, 0,
                            op->beat_count, op->row_count,
                            op->src_row_stride, op->dst_row_stride,
                            dma_tag);
            } else {
                dma_load(op->dram_addr, op->spm_addr, 0, op->beat_count, dma_tag);
            }
            prefetch_last_tag = dma_tag;
        }
    }
}

static void prefetch_wait_all(void) {
    if (prefetch_count > 0) {
        dma_wait_tag(prefetch_last_tag);
        prefetch_count = 0;
    }
}

static inline void prefetch_wave_inputs_generic(const TilingParams* t,
                                                const SpatialDmaRuntime* spatial,
                                                const WaveRuntime* wave) {
    if (!wave->valid) {
        return;
    }

    prefetch_count = 0;

    if (t->input_pad_enable) {
        return;
    }

    if (wave->need_ps_dma) {
        if (plane_is_parallel(t, 0u) && (t->dma_ps_words_per_bank > 0u)) {
            prefetch_enqueue_parallel_words(wave->dram_ps, wave->spm_ps,
                                            t->dma_ps_words,
                                            t->dma_ps_words_per_bank,
                                            t->bank_depth_bytes);
        } else {
            prefetch_enqueue_linear(wave->dram_ps, wave->spm_ps, t->dma_ps_words);
        }
    }

    if (plane_is_parallel(t, 1u) && (t->dma_pd_words_per_bank > 0u)) {
        prefetch_enqueue_parallel_words(wave->dram_pd, wave->spm_pd,
                                        t->dma_pd_words,
                                        t->dma_pd_words_per_bank,
                                        t->bank_depth_bytes);
    } else if (plane_is_parallel(t, 1u) && (spatial->pd_rows_per_bank > 0u)) {
        if (t->spatial_2d_dma) {
            prefetch_enqueue_parallel_rows_2d(wave->dram_pd, wave->spm_pd,
                                              wave->pd_row_beats,
                                              wave->pd_row_count,
                                              spatial->pd_rows_per_bank,
                                              t->bank_depth_bytes,
                                              spatial->pd_src_row_stride,
                                              spatial->pd_dst_row_stride);
        } else {
            prefetch_enqueue_parallel_rows(wave->dram_pd, wave->spm_pd,
                                           wave->pd_row_beats,
                                           wave->pd_row_count,
                                           spatial->pd_rows_per_bank,
                                           t->bank_depth_bytes);
        }
    } else if (t->spatial_2d_dma) {
        prefetch_enqueue_2d(wave->dram_pd, wave->spm_pd,
                            wave->pd_row_beats,
                            wave->pd_row_count,
                            spatial->pd_src_row_stride,
                            spatial->pd_dst_row_stride);
    } else {
        prefetch_enqueue_linear(wave->dram_pd, wave->spm_pd, t->dma_pd_words);
    }

    prefetch_start();
}

static inline void prefetch_wave_inputs_conv_3x3(const TilingParams* t,
                                                 const SpatialDmaRuntime* spatial,
                                                 const WaveRuntime* wave) {
    if (!wave->valid) {
        return;
    }

    prefetch_count = 0;

    if (t->input_pad_enable) {
        return;
    }

    if (wave->need_ps_dma) {
        prefetch_enqueue_linear(wave->dram_ps, wave->spm_ps, t->dma_ps_words);
    }

    prefetch_enqueue_2d(wave->dram_pd, wave->spm_pd,
                        wave->pd_row_beats,
                        wave->pd_row_count,
                        spatial->pd_src_row_stride,
                        spatial->pd_dst_row_stride);

    prefetch_start();
}

static inline void reset_spatial_dma_runtime(SpatialDmaRuntime* spatial) {
    spatial->pd_input_halo = 0;
    spatial->pd_input_w_halo = 0;
    spatial->pd_words_per_spatial = 0;
    spatial->pli_words_per_spatial = 0;
    spatial->pd_src_row_stride = 0;
    spatial->pd_dst_row_stride = 0;
    spatial->pli_row_stride = 0;
    spatial->pd_rows_per_bank = 0;
    spatial->pli_rows_per_bank = 0;
    spatial->plo_words_per_spatial = 0;
    spatial->plo_rows_per_bank = 0;
    spatial->plo_src_row_stride = 0;
    spatial->plo_dst_row_stride = 0;
}

static inline void init_spatial_dma_runtime_generic(const TilingParams* t,
                                                    SpatialDmaRuntime* spatial) {
    reset_spatial_dma_runtime(spatial);

    if (t->spatial_2d_dma) {
        uint32_t pd_rows = plane_is_parallel(t, 1u) && (t->dma_pd_rows_per_bank > 0u)
                         ? t->dma_pd_rows_per_bank : t->tile_h_in;
        uint32_t pli_rows = plane_is_parallel(t, 2u) && (t->dma_pli_rows_per_bank > 0u)
                          ? t->dma_pli_rows_per_bank : t->tile_h_out;
        uint32_t plo_rows = plane_is_parallel(t, 3u) && (t->dma_plo_rows_per_bank > 0u)
                          ? t->dma_plo_rows_per_bank : t->tile_h_out;
        uint32_t plo_words = plane_is_parallel(t, 3u) && (t->dma_plo_words_per_bank > 0u)
                           ? t->dma_plo_words_per_bank : t->dma_plo_words;
        uint32_t pd_full_row_beats = t->dma_pd_words / pd_rows;
        uint32_t pli_full_row_beats = (t->dma_pli_words > 0u) ? (t->dma_pli_words / pli_rows) : 0u;
        uint32_t plo_full_row_beats = plo_words / plo_rows;

        spatial->pd_input_halo = t->tile_h_in - t->tile_h_out;
        spatial->pd_input_w_halo = t->tile_w_in - t->tile_w_out;
        spatial->pd_words_per_spatial = pd_full_row_beats / t->tile_w_in;
        spatial->pli_words_per_spatial = (t->dma_pli_words > 0u) ? (pli_full_row_beats / t->tile_w_out) : 0u;
        spatial->pd_src_row_stride = t->dram_pd_h_stride / t->tile_h_out;
        spatial->pd_dst_row_stride = pd_full_row_beats * BEAT_BYTES;
        spatial->pli_row_stride = pli_full_row_beats * BEAT_BYTES;
        spatial->pd_rows_per_bank = pd_rows;
        spatial->pli_rows_per_bank = pli_rows;
        spatial->plo_words_per_spatial = plo_full_row_beats / t->tile_w_out;
        spatial->plo_rows_per_bank = plo_rows;
        spatial->plo_src_row_stride = plo_full_row_beats * BEAT_BYTES;
        spatial->plo_dst_row_stride = t->dram_out_row_stride;
    }
}

static inline void init_spatial_dma_runtime_conv_3x3(const TilingParams* t,
                                                     SpatialDmaRuntime* spatial) {
    uint32_t pd_full_row_beats;
    uint32_t pli_full_row_beats;
    uint32_t plo_full_row_beats;

    reset_spatial_dma_runtime(spatial);

    pd_full_row_beats = t->dma_pd_words / t->tile_h_in;
    pli_full_row_beats = (t->dma_pli_words > 0u) ? (t->dma_pli_words / t->tile_h_out) : 0u;
    plo_full_row_beats = t->dma_plo_words / t->tile_h_out;

    spatial->pd_input_halo = t->tile_h_in - t->tile_h_out;
    spatial->pd_input_w_halo = t->tile_w_in - t->tile_w_out;
    spatial->pd_words_per_spatial = pd_full_row_beats / t->tile_w_in;
    spatial->pli_words_per_spatial = (t->dma_pli_words > 0u) ? (pli_full_row_beats / t->tile_w_out) : 0u;
    spatial->pd_src_row_stride = t->dram_pd_h_stride / t->tile_h_out;
    spatial->pd_dst_row_stride = pd_full_row_beats * BEAT_BYTES;
    spatial->pli_row_stride = pli_full_row_beats * BEAT_BYTES;
    spatial->plo_words_per_spatial = plo_full_row_beats / t->tile_w_out;
    spatial->plo_src_row_stride = plo_full_row_beats * BEAT_BYTES;
    spatial->plo_dst_row_stride = t->dram_out_row_stride;
}

static inline void dma_load_pd_wave_sync(const TilingParams* t,
                                         const SpatialDmaRuntime* spatial,
                                         const WaveRuntime* wave) {
    if (t->input_pad_enable) {
        if (plane_is_parallel(t, 1u) && (spatial->pd_rows_per_bank > 0u)) {
            dma_load_parallel_rows_2d_pad_sync(wave->dram_pd, wave->spm_pd,
                                               wave->pd_row_beats,
                                               wave->pd_row_count,
                                               spatial->pd_rows_per_bank,
                                               t->bank_depth_bytes,
                                               spatial->pd_src_row_stride,
                                               spatial->pd_dst_row_stride,
                                               wave->pd_pad_window_h0,
                                               wave->pd_pad_window_w0,
                                               t->input_src_h,
                                               t->input_src_w,
                                               spatial->pd_words_per_spatial,
                                               t->input_fill_mode,
                                               t->input_fill_value_lo,
                                               t->input_fill_value_hi);
        } else {
            dma_load_2d_pad_sync(wave->dram_pd, wave->spm_pd,
                                 wave->pd_row_beats,
                                 wave->pd_row_count,
                                 spatial->pd_src_row_stride,
                                 spatial->pd_dst_row_stride,
                                 wave->pd_pad_window_h0,
                                 wave->pd_pad_window_w0,
                                 t->input_src_h,
                                 t->input_src_w,
                                 spatial->pd_words_per_spatial,
                                 t->input_fill_mode,
                                 t->input_fill_value_lo,
                                 t->input_fill_value_hi);
        }
        return;
    }

    if (plane_is_parallel(t, 1u) && (t->dma_pd_words_per_bank > 0u)) {
        dma_load_parallel_words_sync(wave->dram_pd, wave->spm_pd,
                                     t->dma_pd_words,
                                     t->dma_pd_words_per_bank,
                                     t->bank_depth_bytes);
    } else if (plane_is_parallel(t, 1u) && (spatial->pd_rows_per_bank > 0u)) {
        if (t->spatial_2d_dma) {
            dma_load_parallel_rows_2d_sync(wave->dram_pd, wave->spm_pd,
                                           wave->pd_row_beats,
                                           wave->pd_row_count,
                                           spatial->pd_rows_per_bank,
                                           t->bank_depth_bytes,
                                           spatial->pd_src_row_stride,
                                           spatial->pd_dst_row_stride);
        } else {
            dma_load_parallel_rows_sync(wave->dram_pd, wave->spm_pd,
                                        wave->pd_row_beats,
                                        wave->pd_row_count,
                                        spatial->pd_rows_per_bank,
                                        t->bank_depth_bytes);
        }
    } else if (t->spatial_2d_dma) {
        dma_load_2d_sync(wave->dram_pd, wave->spm_pd,
                         wave->pd_row_beats, wave->pd_row_count,
                         spatial->pd_src_row_stride, spatial->pd_dst_row_stride);
    } else {
        dma_load_sync(wave->dram_pd, wave->spm_pd, t->dma_pd_words);
    }
}

static inline void dma_writeback_plo_wave_sync(const TilingParams* t,
                                               const SpatialDmaRuntime* spatial,
                                               const WaveRuntime* wave) {
    if (plane_is_parallel(t, 3u) && (spatial->plo_rows_per_bank > 0u)) {
        if (t->spatial_2d_dma) {
            if (t->output_epilogue != DMA_EPILOGUE_NONE) {
                dma_store_parallel_rows_2d_epilogue_sync(wave->spm_plo, wave->dram_out,
                                                         wave->plo_row_beats,
                                                         wave->plo_row_count,
                                                         spatial->plo_rows_per_bank,
                                                         t->bank_depth_bytes,
                                                         spatial->plo_src_row_stride,
                                                         spatial->plo_dst_row_stride,
                                                         t->output_epilogue,
                                                         t->output_epilogue_param0);
            } else {
                dma_store_parallel_rows_2d_sync(wave->spm_plo, wave->dram_out,
                                                wave->plo_row_beats,
                                                wave->plo_row_count,
                                                spatial->plo_rows_per_bank,
                                                t->bank_depth_bytes,
                                                spatial->plo_src_row_stride,
                                                spatial->plo_dst_row_stride);
            }
        } else {
            dma_store_parallel_rows_sync(wave->spm_plo, wave->dram_out,
                                         wave->plo_row_beats,
                                         wave->plo_row_count,
                                         spatial->plo_rows_per_bank,
                                         t->bank_depth_bytes);
        }
    } else if (t->spatial_2d_dma) {
        if (t->output_epilogue != DMA_EPILOGUE_NONE) {
            dma_store_2d_epilogue_sync(wave->spm_plo, wave->dram_out,
                                       wave->plo_row_beats, wave->plo_row_count,
                                       spatial->plo_src_row_stride,
                                       spatial->plo_dst_row_stride,
                                       t->output_epilogue,
                                       t->output_epilogue_param0);
        } else {
            dma_store_2d_sync(wave->spm_plo, wave->dram_out,
                              wave->plo_row_beats, wave->plo_row_count,
                              spatial->plo_src_row_stride,
                              spatial->plo_dst_row_stride);
        }
    } else if (t->output_epilogue != DMA_EPILOGUE_NONE) {
        dma_store_2d_epilogue_sync(wave->spm_plo, wave->dram_out,
                                   t->dma_plo_words, 1u,
                                   0u, 0u,
                                   t->output_epilogue,
                                   t->output_epilogue_param0);
    } else {
        dma_store_sync(wave->spm_plo, wave->dram_out, t->dma_plo_words);
    }
}

static inline void dma_load_bias_generic(const TilingParams* t,
                                         const SpatialDmaRuntime* spatial,
                                         const WaveRuntime* wave) {
    if (!wave->need_bias_dma) {
        return;
    }

    if (plane_is_parallel(t, 2u) && (spatial->pli_rows_per_bank > 0u)) {
        if (t->spatial_2d_dma) {
            dma_load_parallel_rows_2d_sync(wave->dram_bias, wave->spm_pli,
                                           wave->pli_row_beats,
                                           wave->pli_row_count,
                                           spatial->pli_rows_per_bank,
                                           t->bank_depth_bytes,
                                           spatial->pli_row_stride,
                                           spatial->pli_row_stride);
        } else {
            dma_load_parallel_rows_sync(wave->dram_bias, wave->spm_pli,
                                        wave->pli_row_beats,
                                        wave->pli_row_count,
                                        spatial->pli_rows_per_bank,
                                        t->bank_depth_bytes);
        }
    } else {
        dma_load_sync(wave->dram_bias, wave->spm_pli, t->dma_pli_words);
    }
}

static inline void dma_load_bias_conv_3x3(const TilingParams* t,
                                          const WaveRuntime* wave) {
    if (!wave->need_bias_dma) {
        return;
    }
    dma_load_sync(wave->dram_bias, wave->spm_pli, t->dma_pli_words);
}

static inline void ensure_wave_inputs_ready_generic(const TilingParams* t,
                                                    const SpatialDmaRuntime* spatial,
                                                    const WaveRuntime* wave,
                                                    uint32_t wave_count) {
    if (wave_count == 0u || t->input_pad_enable) {
        dma_load_bias_generic(t, spatial, wave);

        if (wave->need_ps_dma) {
            if (plane_is_parallel(t, 0u) && (t->dma_ps_words_per_bank > 0u)) {
                dma_load_parallel_words_sync(wave->dram_ps, wave->spm_ps,
                                             t->dma_ps_words,
                                             t->dma_ps_words_per_bank,
                                             t->bank_depth_bytes);
            } else {
                dma_load_sync(wave->dram_ps, wave->spm_ps, t->dma_ps_words);
            }
        }

        dma_load_pd_wave_sync(t, spatial, wave);
    } else {
        prefetch_wait_all();
        dma_load_bias_generic(t, spatial, wave);
    }
}

static inline void ensure_wave_inputs_ready_conv_3x3(const TilingParams* t,
                                                     const SpatialDmaRuntime* spatial,
                                                     const WaveRuntime* wave,
                                                     uint32_t wave_count) {
    if (wave_count == 0u || t->input_pad_enable) {
        dma_load_bias_conv_3x3(t, wave);

        if (wave->need_ps_dma) {
            dma_load_sync(wave->dram_ps, wave->spm_ps, t->dma_ps_words);
        }

        dma_load_pd_wave_sync(t, spatial, wave);
    } else {
        prefetch_wait_all();
        dma_load_bias_conv_3x3(t, wave);
    }
}

static inline void writeback_wave_generic(const TilingParams* t,
                                          const SpatialDmaRuntime* spatial,
                                          const WaveRuntime* wave) {
    dma_writeback_plo_wave_sync(t, spatial, wave);
}

static inline void writeback_wave_conv_3x3(const TilingParams* t,
                                           const SpatialDmaRuntime* spatial,
                                           const WaveRuntime* wave) {
    dma_writeback_plo_wave_sync(t, spatial, wave);
}

typedef void (*SpatialRuntimeInitFn)(const TilingParams* t,
                                     SpatialDmaRuntime* spatial);
typedef void (*WaveEnsureReadyFn)(const TilingParams* t,
                                  const SpatialDmaRuntime* spatial,
                                  const WaveRuntime* wave,
                                  uint32_t wave_count);
typedef void (*WavePrefetchFn)(const TilingParams* t,
                               const SpatialDmaRuntime* spatial,
                               const WaveRuntime* wave);
typedef void (*WaveWritebackFn)(const TilingParams* t,
                                const SpatialDmaRuntime* spatial,
                                const WaveRuntime* wave);

static inline void patch_wave_spatial_agus(const LayerConfig* cfg,
                                           const WaveRuntime* wave) {
    const TilingParams* t = &cfg->tiling;
    uint32_t pd_iter0 = cfg->agu_pd.regs[2] & 0xFFFFu;
    uint32_t pd_iter3 = (cfg->agu_pd.regs[3] >> 16) & 0xFFFFu;
    uint32_t pli_iter0 = cfg->agu_pli.regs[2] & 0xFFFFu;
    uint32_t pli_iter3 = (cfg->agu_pli.regs[3] >> 16) & 0xFFFFu;
    uint32_t plo_iter0 = cfg->agu_plo.regs[2] & 0xFFFFu;
    uint32_t plo_iter3 = (cfg->agu_plo.regs[3] >> 16) & 0xFFFFu;

    bcast_agu_write(AGU_PD, AGU_REG_ITER01,
                    (wave->valid_h_in << 16) | pd_iter0);
    bcast_agu_write(AGU_PD, AGU_REG_ITER23,
                    (pd_iter3 << 16) | wave->valid_w_in);
    bcast_agu_write(AGU_PD, AGU_REG_STRIDE1,
                    scale_stride_for_extent(cfg->agu_pd.regs[5],
                                            t->tile_w_in,
                                            wave->valid_w_in));

    bcast_agu_write(AGU_PLI, AGU_REG_ITER01,
                    (wave->valid_h_out << 16) | pli_iter0);
    bcast_agu_write(AGU_PLI, AGU_REG_ITER23,
                    (pli_iter3 << 16) | wave->valid_w_out);
    bcast_agu_write(AGU_PLI, AGU_REG_STRIDE1,
                    scale_stride_for_extent(cfg->agu_pli.regs[5],
                                            t->tile_w_out,
                                            wave->valid_w_out));

    bcast_agu_write(AGU_PLO, AGU_REG_ITER01,
                    (wave->valid_h_out << 16) | plo_iter0);
    bcast_agu_write(AGU_PLO, AGU_REG_ITER23,
                    (plo_iter3 << 16) | wave->valid_w_out);
    bcast_agu_write(AGU_PLO, AGU_REG_STRIDE1,
                    scale_stride_for_extent(cfg->agu_plo.regs[5],
                                            t->tile_w_out,
                                            wave->valid_w_out));
}

/* ═══════════════════════════════════════════════════════
 * run_loop_tiling_common — Core tiling loop with DMA/compute overlap
 * ═══════════════════════════════════════════════════════ */
static void run_loop_tiling_common(const LayerConfig* cfg,
                                   SpatialRuntimeInitFn init_spatial_runtime,
                                   WaveEnsureReadyFn ensure_wave_inputs_ready,
                                   WavePrefetchFn prefetch_wave_inputs_fn,
                                   WaveWritebackFn writeback_wave_fn) {
    const TilingParams* t = &cfg->tiling;
    uint32_t wave_count = 0;
    SpatialDmaRuntime spatial;
    WaveCoord current_coord = make_first_wave_coord(t);
    WaveCoord next_coord;
    WaveRuntime wave_slots[2];
    WaveRuntime* current_wave = &wave_slots[0];
    WaveRuntime* next_wave = &wave_slots[1];

    /* One-time init of constant DMA staging registers */
    dma_init_linear();

    init_spatial_runtime(t, &spatial);

    next_coord.oc = 0;
    next_coord.h = 0;
    next_coord.w = 0;
    next_coord.ic = 0;
    next_coord.valid = 0;

    build_wave_runtime(t, &spatial, &current_coord, wave_count, current_wave);

    /* ── Layer-scoped cluster start (once, before all waves) ──
     * The PE program's KERNEL_LOOP_INNER/OUTER are patched to cover
     * all waves.  PE stalls between waves waiting for HDDU-driven
     * data, then continues when the next wave's HDDU starts.
     * This keeps NoC/PE under layer-scope control while preserving
     * wave-scope direct HDDU/AGU/SPM re-arm below.
     * It also avoids the spm_drop_noc_resp workaround entirely — keeping
     * PE running lets it drain any residual NoC responses naturally. */
    cluster_start_layer();

    while (current_wave->valid) {

        /* Phase 1: Ensure current data is ready */
        ensure_wave_inputs_ready(t, &spatial, current_wave, wave_count);

        /* Phase 2: SPM group mapping */
        bcast_write32(SPM_CONFIG_MAP,    current_wave->spm_map);
        bcast_write32(SPM_CONFIG_UPDATE, 0x01u);

        /* Phase 3: Only base_addr changes per wave.
         * The layer-scope AGU iter/stride/control state stays programmed
         * across HDDU STOP + AGU idle boundaries. */
        patch_wave_spatial_agus(cfg, current_wave);
        bcast_agu_write(AGU_PS,  AGU_REG_BASE_ADDR, current_wave->agu_base_ps);
        bcast_agu_write(AGU_PD,  AGU_REG_BASE_ADDR, current_wave->agu_base_pd);
        bcast_agu_write(AGU_PLI, AGU_REG_BASE_ADDR, current_wave->agu_base_pli);
        bcast_agu_write(AGU_PLO, AGU_REG_BASE_ADDR, current_wave->agu_base_plo);

        /* Phase 4: Start HDDU compute.
         *
         * PE is already running (started once before the wave loop).
         * Each wave only re-arms the HDDU/AGU.  The PE stalls on NoC
         * reads between waves and resumes automatically when the HDDU
         * begins driving new data. */
        bcast_write32(HDDU_BASE + HDDU_PLANE_EN,   cfg->hddu_plane_en);
        bcast_write32(HDDU_BASE + HDDU_PLANE_MODE, cfg->hddu_plane_mode);
        bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_START);  /* cfg_hddu_global START */

        /* Phase 5: DMA prefetch next wave (overlap with compute) */
        {
            copy_wave_coord(&next_coord, &current_coord);
            if (advance_wave_coord(t, &next_coord)) {
                build_wave_runtime(t, &spatial, &next_coord, wave_count + 1u, next_wave);
                prefetch_wave_inputs_fn(t, &spatial, next_wave);
            } else {
                next_wave->valid = 0;
            }
        }

        /* Phase 6: Wait HDDU issue done for the current wave */
        wait_all_clusters_hddu_done(cfg->num_clusters);

        /* Phase 7: Stop HDDU and wait for AGU idle at the wave boundary.
         * PE stays running — it stalls waiting for the next wave's data.
         * Layer-end STOP_PE is deferred until the full tiling loop finishes. */
        bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_STOP);  /* STOP */
        wait_all_clusters_agu_idle(cfg->num_clusters);

        /* Phase 8: DMA writeback (last ic tile only) — SPM→DRAM */
        if (current_wave->is_last_ic) {
            writeback_wave_fn(t, &spatial, current_wave);
        }

        copy_wave_coord(&current_coord, &next_coord);
        {
            WaveRuntime* finished_wave = current_wave;
            current_wave = next_wave;
            next_wave = finished_wave;
        }
        wave_count++;
    }

    /* ── Layer-scoped cluster graceful quiesce (once, after all waves) ──
     * The PE program should have reached HALT by now (all
     * KERNEL_LOOP_OUTER × KERNEL_LOOP_INNER iterations completed).
     * Cluster STOP is now part of the correctness-critical layer-end path:
     * it blocks new ingress, drains residual router state, and only then
     * allows the next layer to re-arm the cluster. */
    cluster_stop_layer();
    wait_all_clusters_cluster_quiesced(cfg->num_clusters);
}

void run_loop_tiling_conv_1x1(const LayerConfig* cfg) {
    run_loop_tiling_common(cfg,
                           init_spatial_dma_runtime_generic,
                           ensure_wave_inputs_ready_generic,
                           prefetch_wave_inputs_generic,
                           writeback_wave_generic);
}

void run_loop_tiling_conv_3x3(const LayerConfig* cfg) {
    run_loop_tiling_common(cfg,
                           init_spatial_dma_runtime_conv_3x3,
                           ensure_wave_inputs_ready_conv_3x3,
                           prefetch_wave_inputs_conv_3x3,
                           writeback_wave_conv_3x3);
}

static inline uint8_t gemm_resident_full_n_enabled(const TilingParams* t) {
    return (t->num_ic_tiles == 1u)
    && (t->gemm_resident_m_tiles == t->num_oc_tiles)
        && (t->gemm_resident_n_tiles == t->num_h_tiles);
}

static inline uint32_t gemm_ps_agu_tile_words(const TilingParams* t) {
    if (plane_is_parallel(t, 0u) && (t->dma_ps_words_per_bank > 0u)) {
        return t->dma_ps_words_per_bank;
    }
    return t->dma_ps_words;
}

static inline uint32_t gemm_pd_agu_tile_words(const TilingParams* t) {
    if (plane_is_parallel(t, 1u) && (t->dma_pd_words_per_bank > 0u)) {
        return t->dma_pd_words_per_bank;
    }
    return t->dma_pd_words;
}

static inline void dma_load_gemm_ps_resident_sync(const TilingParams* t) {
    if (plane_is_parallel(t, 0u) && (t->dma_ps_words_per_bank > 0u)) {
        for (uint32_t n_tile = 0u; n_tile < t->gemm_resident_n_tiles; ++n_tile) {
            dma_load_parallel_words_sync(
                t->dram_weight_base + n_tile * t->dram_ps_h_stride,
                t->spm_ping[0] + n_tile * t->dma_ps_words_per_bank * BEAT_BYTES,
                t->dma_ps_words,
                t->dma_ps_words_per_bank,
                t->bank_depth_bytes
            );
        }
    } else {
        dma_load_sync(t->dram_weight_base, t->spm_ping[0],
                      t->gemm_resident_n_tiles * t->dma_ps_words);
    }
}

static inline void dma_load_gemm_pd_resident_sync(const TilingParams* t,
                                                  uint32_t dram_pd,
                                                  uint32_t m_tiles) {
    if (plane_is_parallel(t, 1u) && (t->dma_pd_words_per_bank > 0u)) {
        for (uint32_t local_m = 0u; local_m < m_tiles; ++local_m) {
            dma_load_parallel_words_sync(
                dram_pd + local_m * t->dram_pd_oc_stride,
                t->spm_ping[1] + local_m * t->dma_pd_words_per_bank * BEAT_BYTES,
                t->dma_pd_words,
                t->dma_pd_words_per_bank,
                t->bank_depth_bytes
            );
        }
    } else {
        dma_load_sync(dram_pd, t->spm_ping[1], m_tiles * t->dma_pd_words);
    }
}

static inline void issue_dma_load_async(uint32_t dram_addr,
                                        uint32_t spm_offset,
                                        uint32_t beat_count,
                                        uint32_t* last_tag);

static inline void dma_load_gemm_pd_resident_tile_async(const TilingParams* t,
                                                        uint32_t dram_pd,
                                                        uint32_t local_m,
                                                        uint32_t* last_tag) {
    if (plane_is_parallel(t, 1u) && (t->dma_pd_words_per_bank > 0u)) {
        uint32_t word_start = 0u;
        uint32_t banks = active_parallel_words(t->dma_pd_words,
                                               t->dma_pd_words_per_bank);
        uint32_t spm_base = t->spm_ping[1]
                          + local_m * t->dma_pd_words_per_bank * BEAT_BYTES;

        for (uint32_t b = 0u; b < banks; ++b) {
            uint32_t bank_words = bank_words_for(t->dma_pd_words,
                                                 t->dma_pd_words_per_bank,
                                                 b);
            if (bank_words == 0u) {
                break;
            }
            issue_dma_load_async(dram_pd + word_start * BEAT_BYTES,
                                 spm_base + b * t->bank_depth_bytes,
                                 bank_words,
                                 last_tag);
            word_start += bank_words;
        }
    } else {
        issue_dma_load_async(dram_pd,
                             t->spm_ping[1] + local_m * t->dma_pd_words * BEAT_BYTES,
                             t->dma_pd_words,
                             last_tag);
    }
}

static inline void issue_dma_load_async(uint32_t dram_addr,
                                        uint32_t spm_offset,
                                        uint32_t beat_count,
                                        uint32_t* last_tag) {
    dma_tag++;
    dma_load(dram_addr, spm_offset, 0, beat_count, dma_tag);
    *last_tag = dma_tag;
}

static inline void issue_dma_load_2d_async(uint32_t dram_addr,
                                           uint32_t spm_offset,
                                           uint32_t row_beats,
                                           uint32_t row_count,
                                           uint32_t src_row_stride,
                                           uint32_t dst_row_stride,
                                           uint32_t* last_tag) {
    dma_tag++;
    dma_load_2d(dram_addr, spm_offset, 0,
                row_beats, row_count,
                src_row_stride, dst_row_stride,
                dma_tag);
    *last_tag = dma_tag;
}

static inline void issue_dma_store_2d_async(uint32_t spm_offset,
                                            uint32_t dram_addr,
                                            uint32_t row_beats,
                                            uint32_t row_count,
                                            uint32_t src_row_stride,
                                            uint32_t dst_row_stride,
                                            uint32_t* last_tag) {
    dma_tag++;
    dma_store_2d(spm_offset, dram_addr, 0,
                 row_beats, row_count,
                 src_row_stride, dst_row_stride,
                 dma_tag);
    *last_tag = dma_tag;
}

static inline uint32_t gemm_ps_resident_spm_offset(const TilingParams* t,
                                                   uint32_t n_tile) {
    if (plane_is_parallel(t, 0u) && (t->dma_ps_words_per_bank > 0u)) {
        return t->spm_ping[0] + n_tile * t->dma_ps_words_per_bank * BEAT_BYTES;
    }
    return t->spm_ping[0] + n_tile * t->dma_ps_words * BEAT_BYTES;
}

static inline uint32_t gemm_resident_spm_col_stride_bytes(uint32_t resident_n_tiles,
                                                          uint32_t tile_words) {
    return resident_n_tiles * tile_words * BEAT_BYTES;
}

static inline void dma_load_gemm_ps_resident_tile_async(const TilingParams* t,
                                                        uint32_t n_tile,
                                                        uint32_t* last_tag) {
    uint32_t dram_addr = t->dram_weight_base + n_tile * t->dram_ps_h_stride;
    uint32_t spm_base = gemm_ps_resident_spm_offset(t, n_tile);

    if (plane_is_parallel(t, 0u) && (t->dma_ps_words_per_bank > 0u)) {
        uint32_t word_start = 0u;
        uint32_t banks = active_parallel_words(t->dma_ps_words,
                                               t->dma_ps_words_per_bank);
        for (uint32_t b = 0u; b < banks; ++b) {
            uint32_t bank_words = bank_words_for(t->dma_ps_words,
                                                 t->dma_ps_words_per_bank,
                                                 b);
            if (bank_words == 0u) {
                break;
            }
            issue_dma_load_async(dram_addr + word_start * BEAT_BYTES,
                                 spm_base + b * t->bank_depth_bytes,
                                 bank_words,
                                 last_tag);
            word_start += bank_words;
        }
    } else {
        issue_dma_load_async(dram_addr, spm_base, t->dma_ps_words, last_tag);
    }
}

static inline void dma_load_gemm_pli_resident_tile_async(const TilingParams* t,
                                                         uint32_t resident_m_tiles,
                                                         uint32_t n_tile,
                                                         uint32_t* last_tag) {
    uint32_t spm_stride_bytes;

    if ((resident_m_tiles == 0u) || (t->dma_pli_words == 0u)) {
        return;
    }

    spm_stride_bytes = gemm_resident_spm_col_stride_bytes(t->gemm_resident_n_tiles,
                                                          t->dma_pli_words);
    issue_dma_load_2d_async(t->dram_bias_base + n_tile * t->dram_bias_h_stride,
                            t->spm_ping[2] + n_tile * t->dma_pli_words * BEAT_BYTES,
                            t->dma_pli_words,
                            resident_m_tiles,
                            t->dram_bias_oc_stride,
                            spm_stride_bytes,
                            last_tag);
}

static inline void dma_load_gemm_resident_tile_sync(const TilingParams* t,
                                                    uint32_t resident_m_tiles,
                                                    uint32_t n_tile) {
    uint32_t last_tag = 0u;

    dma_load_gemm_ps_resident_tile_async(t, n_tile, &last_tag);
    dma_load_gemm_pli_resident_tile_async(t, resident_m_tiles, n_tile, &last_tag);
    if (last_tag != 0u) {
        dma_wait_tag(last_tag);
    }
}

static inline void dma_store_gemm_plo_resident_tile_async(const TilingParams* t,
                                                          uint32_t resident_m_tiles,
                                                          uint32_t n_tile,
                                                          uint32_t* last_tag) {
    uint32_t spm_stride_bytes;

    if (resident_m_tiles == 0u) {
        return;
    }

    spm_stride_bytes = gemm_resident_spm_col_stride_bytes(t->gemm_resident_n_tiles,
                                                          t->dma_plo_words);
    issue_dma_store_2d_async(t->spm_ping[3] + n_tile * t->dma_plo_words * BEAT_BYTES,
                             t->dram_output_base + n_tile * t->dram_out_h_stride,
                             t->dma_plo_words,
                             resident_m_tiles,
                             spm_stride_bytes,
                             t->dram_out_oc_stride,
                             last_tag);
}

static inline void run_loop_tiling_gemm_resident_full_n(const LayerConfig* cfg) {
    const TilingParams* t = &cfg->tiling;
    uint32_t resident_n_tiles = t->gemm_resident_n_tiles;
    uint32_t resident_m_tiles = t->gemm_resident_m_tiles;
    uint32_t pd_preload_m_tiles = t->gemm_pd_preload_m_tiles;
    uint32_t ps_tile_words = gemm_ps_agu_tile_words(t);
    uint32_t pd_tile_words = gemm_pd_agu_tile_words(t);
    uint32_t pd_iter2 = cfg->agu_pd.regs[3] & 0xFFFFu;
    uint32_t pli_iter2 = cfg->agu_pli.regs[3] & 0xFFFFu;
    uint32_t plo_iter2 = cfg->agu_plo.regs[3] & 0xFFFFu;
    uint32_t prefetch_tag = 0u;
    uint32_t store_tag = 0u;

    if ((pd_preload_m_tiles == 0u) || (pd_preload_m_tiles > resident_m_tiles)) {
        pd_preload_m_tiles = resident_m_tiles;
    }

    dma_init_linear();

    dma_load_gemm_pd_resident_sync(t, t->dram_input_base, pd_preload_m_tiles);
    dma_load_gemm_resident_tile_sync(t, resident_m_tiles, 0u);

    bcast_agu_write(AGU_PD, AGU_REG_ITER23, (resident_m_tiles << 16) | pd_iter2);
    bcast_agu_write(AGU_PD, AGU_REG_STRIDE3, pd_tile_words);
    bcast_agu_write(AGU_PLI, AGU_REG_ITER23, (resident_m_tiles << 16) | pli_iter2);
    bcast_agu_write(AGU_PLI, AGU_REG_STRIDE3, resident_n_tiles * t->dma_pli_words);
    bcast_agu_write(AGU_PLO, AGU_REG_ITER23, (resident_m_tiles << 16) | plo_iter2);
    bcast_agu_write(AGU_PLO, AGU_REG_STRIDE3, resident_n_tiles * t->dma_plo_words);

    cluster_start_layer();

    for (uint32_t n_tile = 0u; n_tile < resident_n_tiles; ++n_tile) {
        uint32_t ps_agu_base = t->agu_ping[0] + n_tile * ps_tile_words;
        uint32_t pli_agu_base = t->agu_ping[2] + n_tile * t->dma_pli_words;
        uint32_t plo_agu_base = t->agu_ping[3] + n_tile * t->dma_plo_words;

        if (prefetch_tag != 0u) {
            dma_wait_tag(prefetch_tag);
            prefetch_tag = 0u;
        }

        bcast_write32(SPM_CONFIG_MAP, t->spm_map_even);
        bcast_write32(SPM_CONFIG_UPDATE, 0x01u);

        bcast_agu_write(AGU_PS,  AGU_REG_BASE_ADDR, ps_agu_base);
        bcast_agu_write(AGU_PD,  AGU_REG_BASE_ADDR, t->agu_ping[1]);
        bcast_agu_write(AGU_PLI, AGU_REG_BASE_ADDR, pli_agu_base);
        bcast_agu_write(AGU_PLO, AGU_REG_BASE_ADDR, plo_agu_base);

        bcast_write32(HDDU_BASE + HDDU_PLANE_EN, cfg->hddu_plane_en);
        bcast_write32(HDDU_BASE + HDDU_PLANE_MODE, cfg->hddu_plane_mode);
        bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_START);

        if (n_tile == 0u) {
            for (uint32_t m_tile = pd_preload_m_tiles; m_tile < resident_m_tiles; ++m_tile) {
                dma_load_gemm_pd_resident_tile_async(
                    t,
                    t->dram_input_base + m_tile * t->dram_pd_oc_stride,
                    m_tile,
                    &prefetch_tag
                );
            }
        }
        if (n_tile + 1u < resident_n_tiles) {
            dma_load_gemm_ps_resident_tile_async(t, n_tile + 1u, &prefetch_tag);
            dma_load_gemm_pli_resident_tile_async(t, resident_m_tiles,
                                                  n_tile + 1u,
                                                  &prefetch_tag);
        }
        if (n_tile > 0u) {
            dma_store_gemm_plo_resident_tile_async(t, resident_m_tiles,
                                                   n_tile - 1u,
                                                   &store_tag);
        }

        wait_all_clusters_hddu_done(cfg->num_clusters);

        bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_STOP);
        wait_all_clusters_agu_idle(cfg->num_clusters);
    }

    dma_store_gemm_plo_resident_tile_async(t, resident_m_tiles,
                                           resident_n_tiles - 1u,
                                           &store_tag);
    if (store_tag != 0u) {
        dma_wait_tag(store_tag);
    }

    cluster_stop_layer();
    wait_all_clusters_cluster_quiesced(cfg->num_clusters);
}

void run_loop_tiling_gemm(const LayerConfig* cfg) {
    const TilingParams* t = &cfg->tiling;

    if (gemm_resident_full_n_enabled(t)) {
        run_loop_tiling_gemm_resident_full_n(cfg);
        return;
    }

    uint32_t wave_count = 0;
    uint32_t prev_ps_dram = 0u;
    uint32_t prev_ps_agu_base = 0u;
    SpatialDmaRuntime spatial;
    WaveCoord current_coord = make_first_wave_coord(t);
    WaveCoord next_coord;
    WaveRuntime wave_slots[2];
    WaveRuntime* current_wave = &wave_slots[0];
    WaveRuntime* next_wave = &wave_slots[1];
    GemmPsCache ps_cache;

    dma_init_linear();

    init_spatial_dma_runtime_generic(t, &spatial);

    next_coord.oc = 0;
    next_coord.h = 0;
    next_coord.w = 0;
    next_coord.ic = 0;
    next_coord.valid = 0;

    ps_cache.valid_mask = 0u;
    build_wave_runtime_gemm(t, &spatial, &current_coord, wave_count, 1u, &ps_cache, current_wave);

    cluster_start_layer();

    while (current_wave->valid) {
        uint32_t hddu_plane_en = cfg->hddu_plane_en;
        uint8_t ps_stream_needed = (wave_count == 0u)
                                || (current_wave->dram_ps != prev_ps_dram);
        uint8_t ps_agu_update_needed = (wave_count == 0u)
                                    || (current_wave->agu_base_ps != prev_ps_agu_base);

        ensure_wave_inputs_ready_generic(t, &spatial, current_wave, wave_count);

        bcast_write32(SPM_CONFIG_MAP,    current_wave->spm_map);
        bcast_write32(SPM_CONFIG_UPDATE, 0x01u);

        if (ps_agu_update_needed) {
            bcast_agu_write(AGU_PS, AGU_REG_BASE_ADDR, current_wave->agu_base_ps);
        }
        bcast_agu_write(AGU_PD,  AGU_REG_BASE_ADDR, current_wave->agu_base_pd);
        bcast_agu_write(AGU_PLI, AGU_REG_BASE_ADDR, current_wave->agu_base_pli);
        bcast_agu_write(AGU_PLO, AGU_REG_BASE_ADDR, current_wave->agu_base_plo);

        if (!ps_stream_needed) {
            hddu_plane_en &= ~0x1u;
        }

        bcast_write32(HDDU_BASE + HDDU_PLANE_EN,   hddu_plane_en);
        bcast_write32(HDDU_BASE + HDDU_PLANE_MODE, cfg->hddu_plane_mode);
        bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_START);

        copy_wave_coord(&next_coord, &current_coord);
        if (advance_wave_coord_gemm(t, &next_coord)) {
            build_wave_runtime_gemm(t, &spatial, &next_coord, wave_count + 1u,
                                    current_wave->ps_buf, &ps_cache, next_wave);
            prefetch_wave_inputs_generic(t, &spatial, next_wave);
        } else {
            next_wave->valid = 0;
        }

        wait_all_clusters_hddu_done(cfg->num_clusters);

        bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_STOP);
        wait_all_clusters_agu_idle(cfg->num_clusters);
        /* GEMM ultra: PS/PD parallel + PLI/PLO scan-chain leave NoC
         * pending responses after HDDU/AGU report idle. Drain the NoC
         * before writeback / next-wave START to avoid PE PLI/PD stall
         * piling up across wave boundaries. */
        // wait_all_clusters_noc_quiesced(cfg->num_clusters);

        if (current_wave->is_last_ic) {
            writeback_wave_generic(t, &spatial, current_wave);
        }

        prev_ps_dram = current_wave->dram_ps;
        prev_ps_agu_base = current_wave->agu_base_ps;
        copy_wave_coord(&current_coord, &next_coord);
        {
            WaveRuntime* finished_wave = current_wave;
            current_wave = next_wave;
            next_wave = finished_wave;
        }
        wave_count++;
    }

    cluster_stop_layer();
    wait_all_clusters_cluster_quiesced(cfg->num_clusters);
}

/* ═══════════════════════════════════════════════════════
 * run_layer_common — Complete layer execution
 * ═══════════════════════════════════════════════════════ */
static void run_layer_common(const LayerConfig* cfg,
                             void (*run_loop_tiling_fn)(const LayerConfig* cfg)) {
    set_cluster_mask(cfg->cluster_mask_lo, cfg->cluster_mask_hi);

    /* Layer-scope owner: NoC/PE lifecycle uses cluster MMIO, while
     * wave-scope HDDU/AGU/SPM programming remains direct below. */
    cluster_set_mode(CLUSTER_MODE_LAYER_MANAGED);

    /* HDDU soft-reset */
    bcast_write32(HDDU_BASE + HDDU_CTRL, HDDU_CTRL_SOFT_RESET);

    /* AGU iter/stride setup (once per layer) */
    cfg_agu_bank(AGU_PS,  &cfg->agu_ps);
    cfg_agu_bank(AGU_PD,  &cfg->agu_pd);
    cfg_agu_bank(AGU_PLI, &cfg->agu_pli);
    cfg_agu_bank(AGU_PLO, &cfg->agu_plo);

    /* HDDU global */
    bcast_write32(HDDU_BASE + HDDU_PLANE_EN,   cfg->hddu_plane_en);
    bcast_write32(HDDU_BASE + HDDU_PLANE_MODE, cfg->hddu_plane_mode);

    /* NoC Reset & Init */
    bcast_write32(NOC_CMD, pack_noc_cmd(NOC_CMD_RESET, 0));
    bcast_write32(NOC_CMD, pack_noc_cmd(NOC_CMD_INIT,  0));

    /* Scan chain (pre-encoded) */
    send_noc_scan_chain(cfg->scan_chain, cfg->scan_chain_len);

    /* Runtime patch + Load PE program */
    pe_patch_runtime(cfg->pe_template, cfg->pe_template_len,
                     cfg->patches, cfg->patch_count);
    load_pe_program(patched_prog, cfg->pe_template_len);

    /* Tiling loop
     * Assumption: the previous layer has already completed its
     * STOP_PE-driven NOC quiesce barrier before this layer re-arms
     * HDDU/NoC/scan-chain state. */
    run_loop_tiling_fn(cfg);
}

void run_layer_conv2d_3x3(const LayerConfig* cfg) {
    run_layer_common(cfg, run_loop_tiling_conv_3x3);
}

void run_layer_conv2d_1x1(const LayerConfig* cfg) {
    run_layer_common(cfg, run_loop_tiling_conv_1x1);
}

void run_layer_gemm(const LayerConfig* cfg) {
    run_layer_common(cfg, run_loop_tiling_gemm);
}
