 * pe_patch_runtime — Runtime PE template patching
 * ═══════════════════════════════════════════════════════ */
static uint16_t patched_prog[64];

#define PE_PATCH_OFFSET_INVALID 0xFFFFu

void pe_patch_runtime(const uint16_t* tmpl, uint32_t tmpl_len,
                      const PePatchEntry* patches, uint32_t patch_count) {
    for (uint32_t i = 0; i < tmpl_len; i++) {
        patched_prog[i] = tmpl[i];
    }
    for (uint32_t i = 0; i < patch_count; i++) {
        uint32_t off = patches[i].offset;
        uint16_t val = patches[i].encoded_val;
        patched_prog[off] = (uint16_t)(((val & 0x3FFu) << 6)
                                       | (patched_prog[off] & 0x3Fu));
    }
}

static inline uint16_t encode_n_minus_one_count(uint32_t raw_value) {
    if (raw_value == 0u) {
        raw_value = 1u;
    }
    return (uint16_t)(raw_value - 1u);
}

static inline uint8_t pe_patch_runtime_count(uint16_t offset, uint32_t raw_value) {
    uint16_t encoded_value;
    uint16_t patched_word;

    if (offset == PE_PATCH_OFFSET_INVALID) {
        return 0u;
    }

    encoded_value = encode_n_minus_one_count(raw_value);
    patched_word = (uint16_t)(((encoded_value & 0x3FFu) << 6)
                              | (patched_prog[offset] & 0x3Fu));

    if (patched_prog[offset] == patched_word) {
        return 0u;
    }

    patched_prog[offset] = patched_word;
    return 1u;
}

