/* ═══════════════════════════════════════════════════════
 * HybridAcc Firmware — PE Payload (Templates + Scan Chains + Patches)
 * Auto-generated by hybridacc-cc — DO NOT EDIT
 * Workload: {{ workload_name }}
 * ═══════════════════════════════════════════════════════ */
#ifndef FIRMWARE_PAYLOAD_H
#define FIRMWARE_PAYLOAD_H

#include <stdint.h>

/* ── Patch Descriptor ── */
typedef struct {
    uint8_t  offset;
    uint16_t encoded_val;
} PePatchEntry;

/* ═══════════════════════════════════════════════════════
 * Pre-encoded Scan Chains
 * ═══════════════════════════════════════════════════════ */
{% for key, sc in scan_chains.items() %}
static const uint32_t {{ sc.symbol }}[] = {
    {% for w in sc.words %}
    {{ "0x%08X" | format(w) }}u{{ "," if not loop.last }}
    {% endfor %}
};
#define {{ sc.symbol | upper }}_LEN  {{ sc.len }}

{% endfor %}

/* ═══════════════════════════════════════════════════════
 * PE Template Binaries (un-patched originals)
 * ═══════════════════════════════════════════════════════ */
{% for name, tmpl in templates.items() %}
static const uint16_t {{ tmpl.symbol }}[] = {
    {% for inst in tmpl.instructions %}
    {{ "0x%04X" | format(inst) }}{{ "," if not loop.last }}  /* {{ loop.index0 }} */
    {% endfor %}
};
#define {{ tmpl.symbol | upper }}_LEN  {{ tmpl.len }}

{% endfor %}

/* ═══════════════════════════════════════════════════════
 * Per-Layer Patch Descriptors
 * ═══════════════════════════════════════════════════════ */
{% for lp in layers %}
static const PePatchEntry {{ lp.patch_symbol }}[] = {
    {% for p in lp.patch_entries %}
    { {{ p.offset }}, {{ p.encoded_val }} }{{ "," if not loop.last }}
    {% endfor %}
};
#define {{ lp.patch_symbol | upper }}_LEN  {{ lp.patch_count }}

{% endfor %}

#endif /* FIRMWARE_PAYLOAD_H */
